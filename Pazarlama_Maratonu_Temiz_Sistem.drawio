    <mxCell id="left_header" value="🍝 MEVCUT DURUM — Spagetti Sistem (BOZUK)" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontStyle=1;fontColor=#b85450;rounded=1;" vertex="1" parent="1">
