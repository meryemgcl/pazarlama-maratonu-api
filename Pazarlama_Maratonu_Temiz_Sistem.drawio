    <!-- SPAGETTİ: 3+1 İLETİŞİM -->
    <mxCell id="l_msg_chaos" value="🔴 AYNI ANDA 4 İLETİŞİM GÖNDERİLİYOR&#xa;↪ SMS (hatalı numara = sistem kilitlenme!)&#xa;↪ E-posta #1 (onay maili)&#xa;↪ E-posta #2 (hoş geldin maili)&#xa;↪ E-posta #3 (bilgilendirme maili)&#xa;(Validasyon yok, döngü riski!)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;align=left;" vertex="1" parent="1">
