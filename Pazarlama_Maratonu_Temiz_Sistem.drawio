    <!-- SPAGETTİ: TELEFON HATASI -->
    <mxCell id="l_tel_bug" value="💀 SİSTEM KİLİTLENME NOKTASI&#xa;Hatalı telefon numarası girildiğinde:&#xa;• Hata mesajı gösterilmiyor&#xa;• Sistem arka planda SMS&#xa;  denemeye devam ediyor&#xa;• Timeout / Crash!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#842029;fontSize=11;fontStyle=1;align=left;strokeWidth=3;" vertex="1" parent="1">
