    <!-- TEKNİK BORÇ LİSTESİ -->
    <mxCell id="l_debt" value="⚠️ TEKNİK BORÇLAR (Technical Debt)&#xa;&#xa;1. Input validasyonu YOK&#xa;2. Sonsuz döngü riski (SMS retry)&#xa;3. Veri tutarsızlığı (3 DB senkronize değil)&#xa;4. Kimlik doğrulama atlanıyor&#xa;5. Race condition (aynı anda 4 işlem)&#xa;6. Hata yönetimi (Error Handling) YOK&#xa;7. Idempotency yok (çift kayıt riski)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
