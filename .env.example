# .env.example — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayıp ".env" olarak kaydedin, ardından gerçek değerleri girin.
# .env dosyasını asla git'e commit etmeyin!

# ── Uygulama ────────────────────────────────────────────────────────────────
APP_NAME="Pazarlama Maratonu Kayıt API"
APP_BASE_URL=http://localhost:8000          # Prod'da: https://api.markamatfagi.com
TOKEN_TTL_HOURS=24

# ── Notion ──────────────────────────────────────────────────────────────────
# Adım 1: https://www.notion.so/my-integrations → New Integration
# Adım 2: Veritabanı sayfasında Share → Integration ekle
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── E-posta (SMTP) ──────────────────────────────────────────────────────────
# Gmail kullanıyorsanız: 2FA açık olmalı + App Password oluşturulmalı
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@markamatfagi.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM="Marka Mutfağı <noreply@markamatfagi.com>"

# ── Slack ────────────────────────────────────────────────────────────────────
# https://api.slack.com/apps → Bot Token Scopes:
#   users:read, users:read.email, channels:manage, groups:write, im:write
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=C0XXXXXXXXXX                # Kanal ayarlarından kopyalayın

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
# https://console.twilio.com/ → Account SID, Auth Token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+905xxxxxxxxx
SMS_ENABLED=true                             # false yaparak SMS'i kapatın

# ── Güvenlik ─────────────────────────────────────────────────────────────────
# Rastgele 32+ karakter bir string girin (python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=buraya_cok_uzun_ve_rastgele_bir_gizli_anahtar_yazin
